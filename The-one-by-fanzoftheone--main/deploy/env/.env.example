# ── THE ONE — Complete Environment Setup ──────────────────────────────────
# Copy to Railway (backend service) and Vercel (frontend project)

# ── BACKEND (Railway) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/theone
CORS_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# ── AI PROVIDERS (pick at least one) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude — live AI brain + 3-6-9 blocks
DEEPSEEK_API_KEY=sk-...               # DeepSeek — cheaper alternative
OPENAI_API_KEY=sk-...                 # ChatGPT

# ── PAYMENTS (Stripe) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...         # From stripe.com/dashboard
STRIPE_WEBHOOK_SECRET=whsec_...       # From stripe webhook endpoint
FRONTEND_URL=https://your-app.vercel.app

# ── STRIPE PRICE IDs (create products in Stripe dashboard first) ──────────
STRIPE_PRICE_NERVOUS_SYSTEM=price_...
STRIPE_PRICE_FANZO_CORE=price_...
STRIPE_PRICE_CONTENT_ENGINE=price_...
STRIPE_PRICE_CONTENT_MACHINE=price_...
STRIPE_PRICE_EMAIL_GROWTH=price_...
STRIPE_PRICE_LITTLE_PRO=price_...
STRIPE_PRICE_MARKETING_AUTO=price_...
STRIPE_PRICE_PRODUCTIVITY=price_...
STRIPE_PRICE_SEO=price_...
STRIPE_PRICE_369_BUILDER=price_...
STRIPE_PRICE_CONSTRUCTION_OPS=price_...
STRIPE_PRICE_PLAY_BETTER=price_...

# ── DEPLOY TOKENS ────────────────────────────────────────────────────────
VERCEL_TOKEN=...                      # vercel.com/account/tokens
RAILWAY_TOKEN=...                     # railway.app/account/tokens

# ── WAREHOUSE (FanzSpot proxy) ────────────────────────────────────────────
WAREHOUSE_URL=https://fanzspot-production.up.railway.app

# ── GMAIL OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://your-backend.railway.app/api/auth/google/callback

# ── CONTENT ENGINE ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
LEONARDO_API_KEY=...

# ── FRONTEND (Vercel) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-backend.railway.app
