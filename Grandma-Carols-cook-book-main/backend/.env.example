# Railway injects DATABASE_URL automatically when you add a Postgres plugin
# No need to set this manually — it's already there in Railway

# Family access code (share this with all grandchildren)
FAMILY_CODE=carol2025

# Session security — change this to something long and random
SESSION_SECRET=change-this-to-something-long-and-random

# Media Storage (S3-compatible — AWS S3, Cloudflare R2, etc.)
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_REGION=us-east-1
STORAGE_BUCKET=carol-cookbook-media
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_PUBLIC_URL=https://carol-cookbook-media.s3.amazonaws.com

# Frontend URL (for CORS)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

PORT=3001
NODE_ENV=development
